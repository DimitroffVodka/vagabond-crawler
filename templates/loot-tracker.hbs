<div class="loot-tracker-container" style="display:flex; flex-direction:column; height:100%; gap:8px; padding:8px;">

  {{!-- Toolbar --}}
  <div style="display:flex; gap:6px; justify-content:flex-end;">
    <button class="lt-copy-btn" type="button" style="padding:4px 10px; cursor:pointer; background:rgba(88,101,242,0.3); border:1px solid rgba(88,101,242,0.6); color:#7289da; border-radius:4px;">
      <i class="fab fa-discord"></i> Copy for Discord
    </button>
    <button class="lt-clear-btn" type="button" style="padding:4px 10px; cursor:pointer; background:rgba(192,57,43,0.2); border:1px solid rgba(192,57,43,0.4); color:#e74c3c; border-radius:4px;">
      <i class="fas fa-trash"></i> Clear Log
    </button>
  </div>

  {{!-- Log entries --}}
  <div style="flex:1; overflow-y:auto; display:flex; flex-direction:column; gap:3px;">
    {{#if entries.length}}
      {{#each entries}}
      <div style="display:flex; align-items:center; gap:8px; padding:4px 8px; background:rgba(0,0,0,0.15); border-radius:4px; font-size:0.9em;">
        <span style="color:#888; font-size:0.8em; width:45px; flex-shrink:0;">{{time}}</span>
        <span style="width:20px; text-align:center; flex-shrink:0;">{{{iconHtml}}}</span>
        <span style="color:#f4c542; font-weight:bold; min-width:80px;">{{player}}</span>
        <span style="color:{{typeColor}}; flex:1;">{{detail}}</span>
        <span style="color:#888; font-size:0.8em;">{{source}}</span>
      </div>
      {{/each}}
    {{else}}
      <div style="text-align:center; color:#888; padding:40px;">
        <i class="fas fa-scroll" style="font-size:2em; display:block; margin-bottom:8px;"></i>
        No loot recorded yet.
      </div>
    {{/if}}
  </div>

</div>
